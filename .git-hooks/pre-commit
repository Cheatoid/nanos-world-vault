#!/bin/sh

# Run packager to ensure metadata stays correct
echo "Running packager to validate metadata..."

# Run dotnet packager project
dotnet run --project ".packager/packager.csproj" --configuration Release

# Check if the packager succeeded
if [ $? -ne 0 ]; then
	echo "ERROR: Packager failed. Please fix the metadata issues before committing."
	exit 1
fi

echo "Packager validation passed."
exit 0
