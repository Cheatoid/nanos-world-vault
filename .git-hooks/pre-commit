#!/usr/bin/env bash

# Run packager to regenerate metadata_gen.lua files for all packages
echo "Running packager to update metadata..."

# Use pre-built binary if available, otherwise fallback to dotnet run
if [ -f "bin/packager.exe" ]; then
	bin/packager.exe
else
	dotnet restore --project ".packager/packager.csproj"
	dotnet build --project ".packager/packager.csproj" --no-restore --configuration Release
	dotnet run --project ".packager/packager.csproj" --no-build --configuration Release --
fi

# Check if packager succeeded
if [ $? -ne 0 ]; then
	echo "ERROR: Packager failed. Please fix issues before committing."
	exit 1
fi

# Stage any updated metadata_gen.lua files (included in current commit)
git add -A "*/Shared/metadata_gen.lua"

exit 0
