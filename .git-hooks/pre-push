#!/bin/sh

# Run packager to regenerate metadata.g.lua files for all packages
echo "Running packager to update metadata..."

dotnet run --project ".packager/packager.csproj" --configuration Release

# Check if packager succeeded
if [ $? -ne 0 ]; then
	echo "ERROR: Packager failed. Aborting push."
	exit 1
fi

# Stage any updated metadata.g.lua files
git add -A "*/Shared/metadata.g.lua"

# Check if there are staged changes
if git diff --cached --quiet; then
	echo "No metadata changes to commit."
else
	# Amend the commit with updated metadata
	git commit --amend --no-edit --no-verify
	echo "Metadata updated and amended to commit."
fi

exit 0
