{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Remove UTF-8 BOM",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/.tools/remove_utf8_bom.ps1"
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Run Packager (generate packages into publish folder)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/.packager/packager.csproj"
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Upload packages to local server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/.packager/packager.csproj",
				"--",
				"--upload-packages",
				"--cli",
				"${workspaceFolder}/.."
				// assume NanosWorldServer is 1 level above
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Upload packages to local server + store",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/.packager/packager.csproj",
				"--",
				"--release",
				"--upload-packages",
				"--cli",
				"${workspaceFolder}/.."
				// assume NanosWorldServer is 1 level above
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Download+Generate+Build Lua 5.4.8 binaries (CMake)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"${workspaceFolder}/.lua/make.cmd",
				"5.4.8",
				"--download"
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Download+Generate+Build Lua 5.4.8 binaries (Premake5)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"${workspaceFolder}/.lua/make.cmd",
				"5.4.8",
				"--download",
				"--premake"
			],
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		}
	]
}
