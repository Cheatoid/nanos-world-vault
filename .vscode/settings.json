{
	"Lua.workspace.checkThirdParty": false,
	"Lua.workspace.ignoreSubmodules": false,
	"Lua.workspace.library": [
		"${workspaceFolder}/.nanos-world",
		"${workspaceFolder}/library/Shared",
		"${workspaceFolder}/library/Shared/@cheatoid/standard"
	],
	"Lua.diagnostics.globals": [],
	"Lua.diagnostics.disable": [
		"different-requires"
	],
	"Lua.runtime.version": "Lua 5.4",
	"Lua.format.enable": true,
	"Lua.format.defaultConfig": {
		"indent_style": "tab",
		"indent_size": "2"
	},
	"[lua]": {
		"editor.defaultFormatter": "sumneko.lua"
	},
	"Lua.hint.setType": true,
	"Lua.hint.enable": true,
	"editor.inlayHints.enabled": "offUnlessPressed",
	"vscord.enable": true,
	"editor.largeFileOptimizations": true,
	"files.exclude": {
		"**/.git/**": true,
		"**/.idea/**": true,
		".lua/**": true,
		".nvim-data/**": true,
		".nvim-win64/**": true,
		"**/.vs/**": true,
		"**/bin/**": true,
		"**/obj/**": true,
		"**/node_modules/**": true,
		"coc": true,
		"publish/**": true
	},
	"files.watcherExclude": {
		"**/.git/**": true,
		"**/.idea/**": true,
		".lua/**": true,
		".nvim-data/**": true,
		".nvim-win64/**": true,
		"**/.vs/**": true,
		"**/bin/**": true,
		"**/obj/**": true,
		"**/node_modules/**": true,
		"coc": true,
		"publish/**": true
	},
	"search.exclude": {
		"**/.git/**": true,
		"**/.idea/**": true,
		"**/.vs/**": true,
		".lua/**": true,
		"**/bin/**": true,
		"**/obj/**": true,
		"**/node_modules/**": true,
		"publish/**": true
	}
}
